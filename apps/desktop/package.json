{
  "name": "@polytrader2/app",
  "version": "1.0.0",
  "description": "Polytrader2 桌面客户端",
  "main": "./out/main/index.js",
  "scripts": {
    "prepare:workspace-packages": "pnpm --workspace-root run prepare:workspace-packages",
    "dev": "electron-vite dev --remoteDebuggingPort 9222 -- --trace-warnings",
    "build": "electron-vite build && pnpm run build:mcp-stdio-bridge",
    "build:mcp-stdio-bridge": "tsup --config mcp-stdio-bridge.tsup.config.ts",
    "build:with-deps": "pnpm --workspace-root run build",
    "start": "electron-vite preview",
    "dist:win": "pnpm --workspace-root run build && pnpm run dist:win:app",
    "dist:win:app": "node scripts/package-win.mjs",
    "dist:mac": "pnpm --workspace-root run build && pnpm run dist:mac:app",
    "dist:mac:app": "node scripts/package-mac.mjs",
    "dist:mac:notarized": "pnpm --workspace-root run build && pnpm run dist:mac:notarized:app",
    "dist:mac:notarized:app": "node scripts/package-mac.mjs --notarize",
    "publish:win": "pnpm --workspace-root run build && pnpm run publish:win:app",
    "publish:win:app": "node scripts/package-win.mjs --publish always",
    "typecheck": "pnpm run typecheck:app",
    "typecheck:app": "vue-tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint . ../../packages/shared ../../packages/event-bus ../../packages/app-preferences ../../packages/mcp-server ../../packages/cache-store ../../packages/contracts/bot-runtime-contract ../../packages/contracts/repository-contract ../../packages/repositories/sqlite-repository ../../packages/repositories/duckdb-repository ../../packages/polymarket-api ../../packages/polymarket-market ../../packages/polymarket-wallet ../../packages/trading-account ../../packages/trading-market ../../packages/trading-strategy ../../packages/strategy-runtime",
    "lint:fix": "eslint . ../../packages/shared ../../packages/event-bus ../../packages/app-preferences ../../packages/mcp-server ../../packages/cache-store ../../packages/contracts/bot-runtime-contract ../../packages/contracts/repository-contract ../../packages/repositories/sqlite-repository ../../packages/repositories/duckdb-repository ../../packages/polymarket-api ../../packages/polymarket-market ../../packages/polymarket-wallet ../../packages/trading-account ../../packages/trading-market ../../packages/trading-strategy ../../packages/strategy-runtime --fix",
    "format": "node scripts/run-prettier.mjs --ignore-path ../../.prettierignore --write . ../../packages/shared ../../packages/event-bus ../../packages/app-preferences ../../packages/mcp-server ../../packages/cache-store ../../packages/contracts/bot-runtime-contract ../../packages/contracts/repository-contract ../../packages/repositories/sqlite-repository ../../packages/repositories/duckdb-repository ../../packages/polymarket-api ../../packages/polymarket-market ../../packages/polymarket-wallet ../../packages/trading-account ../../packages/trading-market ../../packages/trading-strategy ../../packages/strategy-runtime",
    "format:check": "node scripts/run-prettier.mjs --ignore-path ../../.prettierignore --check . ../../packages/shared ../../packages/event-bus ../../packages/app-preferences ../../packages/mcp-server ../../packages/cache-store ../../packages/contracts/bot-runtime-contract ../../packages/contracts/repository-contract ../../packages/repositories/sqlite-repository ../../packages/repositories/duckdb-repository ../../packages/polymarket-api ../../packages/polymarket-market ../../packages/polymarket-wallet ../../packages/trading-account ../../packages/trading-market ../../packages/trading-strategy ../../packages/strategy-runtime",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run format:check",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:rebuild-local": "node scripts/rebuild-local-db.mjs",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "smoke:crypto-events": "node scripts/run-electron-node.mjs scripts/crypto-events-smoke.mjs",
    "smoke:cache-store": "node scripts/cache-store-smoke.mjs",
    "smoke:duckdb-native": "node scripts/run-electron-node.mjs scripts/duckdb-native-smoke.mjs",
    "smoke:event-sync-write": "node scripts/run-electron-node.mjs scripts/event-sync-write-benchmark.mjs",
    "smoke:event-sync-status": "node scripts/run-electron-node.mjs scripts/event-sync-status-smoke.mjs",
    "smoke:event-sync-abort": "node scripts/event-sync-abort-smoke.mjs",
    "smoke:event-sync-renderer-shutdown": "node scripts/run-electron-node.mjs scripts/event-sync-renderer-shutdown-smoke.mjs",
    "smoke:event-sync-shutdown": "node scripts/run-electron-node.mjs scripts/event-sync-shutdown-smoke.mjs",
    "smoke:r2-event-snapshot": "node scripts/r2-event-snapshot-smoke.mjs",
    "smoke:ai-agent-integration": "node scripts/run-electron-node.mjs scripts/ai-agent-integration-smoke.mjs",
    "smoke:mcp-stdio-bridge": "pnpm run build:mcp-stdio-bridge && node scripts/run-electron-node.mjs scripts/mcp-stdio-bridge-smoke.mjs",
    "smoke:sports-sync": "node scripts/run-electron-node.mjs scripts/sports-sync-smoke.mjs",
    "smoke:performance-preference-migration": "node scripts/run-electron-node.mjs scripts/performance-preference-migration-smoke.mjs",
    "smoke:tick-size-support": "node scripts/run-electron-node.mjs scripts/tick-size-support-smoke.mjs",
    "postinstall": "node scripts/postinstall.mjs"
  },
  "type": "module",
  "packageManager": "pnpm@11.5.0",
  "dependencies": {
    "@duckdb/node-api": "1.5.4-r.1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@noble/curves": "1.9.1",
    "@scure/bip32": "1.7.0",
    "@scure/bip39": "1.6.0",
    "@supabase/supabase-js": "^2.110.2",
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.45.2",
    "electron-updater": "^6.8.9",
    "isolated-vm": "6.1.2",
    "isows": "1.0.7",
    "lowdb": "^7.0.1",
    "qrcode": "^1.5.4",
    "typescript": "^6.0.3",
    "viem": "^2.55.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "@eslint/js": "^10.0.1",
    "@lucide/vue": "^1.24.0",
    "@polytrader/app-preferences": "workspace:*",
    "@polytrader/bot-runtime-contract": "workspace:*",
    "@polytrader/bot-vm": "workspace:*",
    "@polytrader/duckdb-repository": "workspace:*",
    "@polytrader/event-bus": "workspace:*",
    "@polytrader/cache-store": "workspace:*",
    "@polytrader/mcp-server": "workspace:*",
    "@polytrader/polymarket-api": "workspace:*",
    "@polytrader/polymarket-market": "workspace:*",
    "@polytrader/polymarket-wallet": "workspace:*",
    "@polytrader/repository-contract": "workspace:*",
    "@polytrader/shared": "workspace:*",
    "@polytrader/sqlite-repository": "workspace:*",
    "@polytrader/strategy-runtime": "workspace:*",
    "@polytrader/system-performance": "workspace:*",
    "@polytrader/trading-account": "workspace:*",
    "@polytrader/trading-market": "workspace:*",
    "@polytrader/trading-strategy": "workspace:*",
    "@polytrader/workflow": "workspace:*",
    "@tailwindcss/vite": "^4.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.3",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-vue": "^6.0.7",
    "drizzle-kit": "^0.31.10",
    "electron": "42.4.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "lightweight-charts": "^5.2.0",
    "monaco-editor": "0.55.1",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.2",
    "typescript-eslint": "^8.63.0",
    "vue": "^3.5.39",
    "vue-eslint-parser": "^10.4.1",
    "vue-i18n": "^11.4.6",
    "vue-tsc": "^3.3.7"
  }
}
