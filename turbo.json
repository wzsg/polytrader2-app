{
  "$schema": "https://turborepo.dev/schema.json",
  "globalDependencies": [
    "eslint.config.js",
    "pnpm-lock.yaml",
    "prettier.config.js",
    "tsconfig.json",
    "tsconfig.references.json"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@polytrader2/app#build": {
      "dependsOn": ["^build"],
      "outputs": ["out/**"]
    },
    "typecheck": {
      "dependsOn": ["^build", "^typecheck"],
      "outputs": []
    },
    "@polytrader2/app#typecheck": {
      "dependsOn": ["^build", "^typecheck"],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "lint:fix": {
      "cache": false
    },
    "format": {
      "cache": false
    },
    "format:check": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
